# TradJS/Bun server port
# Export this in your shell before running the app:
#   export BUN_PORT=3000
# PowerShell:
#   $env:BUN_PORT = "3000"

# New-token discovery source:
# - auto: PumpPortal when configured; otherwise direct Solana Pump program logs.
# - pumpportal: Pump/PumpSwap creation events through subscribeNewToken.
# - solana-rpc: keyless Pump creation discovery through logsSubscribe + getTransaction.
# - dexscreener: newly created DEX Screener profiles only (not every mint).
NEW_TOKEN_STREAM_SOURCE=auto

# Optional, recommended provider for richer creation payloads.
PUMPPORTAL_API_KEY=
# PUMPPORTAL_WS_URL=

# Keyless auto fallback. Replace the public endpoints with your own RPC for
# production reliability and higher rate limits. HELIUS_RPC_URL/HELIUS_WS_URL
# are accepted as aliases.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

# Explicit DEX-profile mode only.
# DEXSCREENER_PROFILE_WS_URL=
DEXSCREENER_PROFILE_POLL_MS=15000

# Optional: pin the pair-metrics tab to specific Solana token addresses.
# Accepts comma- or whitespace-separated addresses; the adapter requests at most 30.
DEXSCREENER_TOKEN_ADDRESSES=

# Server-side snapshot cache. Values are clamped between 10000 and 120000 ms.
DEXSCREENER_CACHE_MS=20000

# Optional REST proxy/test override. Leave unset for https://api.dexscreener.com.
# DEXSCREENER_API_BASE_URL=
