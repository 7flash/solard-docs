# TradJS server
BUN_PORT=3000
SOLARD_START_INDEXER=1

# One WAL-mode database shared by the SQD writer and web readers.
SOLARD_DB_PATH=./solard.db

# SQD Portal market indexer. Hot mode is required for live migrations.
PORTAL_URL=https://portal.sqd.dev/datasets/solana-mainnet
# Set to 1 only when delayed finalized-only markets are explicitly desired.
SQD_MARKET_FINALIZED=0

# One live SQD cursor indexes recent Pump migrations and SOLARD activity.
# There is no automatic historical replay. The v4 hot cursor starts close to head.
SQD_LIVE_LOOKBACK=2000

# Seeded executable markets: SOLARD, ANSEM and FARTCOIN.
SOLARD_SEED_MARKETS=1

SQD_HEARTBEAT_MS=10000
SQD_POLL_MS=1000
SQD_RETRY_MS=3000
METADATA_CONCURRENCY=2
SOLARD_INDEXER_RPC_RPS=1

# Server RPC is used only for seeded pool verification and prioritized
# reserve snapshots/prices. Every call is an individual JSON-RPC request.
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLARD_SERVER_RPC_RPS=3

# Browser RPC is reserved for wallet balance, selected-pair validation and sending.
PUBLIC_SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
PUBLIC_RPC_MAX_RPS=1

PUBLIC_PROGRAM_ID=5cvRkbFXRozP2tZ9VW3xk3HCYZxcojsL69Lq2qzeSLRD
PUBLIC_PUMPSWAP_PROGRAM_ID=pAMMBay6oceH9fJKBRHGP5D4bD4sWpmSwMn52FMfXEA
PUBLIC_COLLATERAL_SYMBOL=SOL
PUBLIC_EXPLORER_BASE=https://solscan.io

# Terminal market window. Non-seed migrations older than this are hidden.
SOLARD_MARKET_MAX_AGE_MS=7200000
# Set to 1 only when old migrated pools should be retained in SQLite/UI.
SQD_KEEP_HISTORICAL_POOLS=0
